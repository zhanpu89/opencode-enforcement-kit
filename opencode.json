{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/*.md"
  ],
  "agent": {
    "coding-executor": {
      "description": "编码执行者。先验证、后编码、再验证的编码流程。用户要求写代码、实现功能时使用。",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "verify-agent": {
      "description": "编码验证者。独立审查代码与设计文档的一致性，输出五维核对报告。不修改任何代码。",
      "mode": "subagent"
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "scripts/gate.sh *": "allow",
      "scripts/verify-coding.sh *": "allow",
      "scripts/doc-gate.sh *": "allow"
    }
  },
  "plugin": [
    ".opencode/plugin/stage-gate.js",
    ".opencode/plugin/verify-gate.js"
  ]
}
